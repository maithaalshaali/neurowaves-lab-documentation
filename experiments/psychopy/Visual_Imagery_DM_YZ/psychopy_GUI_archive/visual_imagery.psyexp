        <Param val="import random&amp;#10;&amp;#10;# Create a list of image names with specified counts&amp;#10;P_image_pool = ['7.jpg'] * 1 + ['9.jpg'] * 1 + ['8.jpg'] * 1&amp;#10;random.shuffle(P_image_pool)&amp;#10;# Initialize a counter&amp;#10;P_image_index = 0" valType="extendedCode" updates="constant" name="Begin Experiment"/>
