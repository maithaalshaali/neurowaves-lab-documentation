        <Param val="import random&amp;#10;&amp;#10;# Create a list of image names with specified counts&amp;#10;B1_image_pool = ['7.jpg'] * 15 + ['9.jpg'] * 15 + ['8.jpg'] * 10&amp;#10;random.shuffle(B1_image_pool)&amp;#10;# Initialize a counter&amp;#10;B1_image_index = 0" valType="extendedCode" updates="constant" name="Begin Experiment"/>
