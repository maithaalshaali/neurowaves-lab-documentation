        <Param val="True" valType="bool" updates="None" name="syncScreenRefresh"/>
        <Param val="Welcome to the experiment!&amp;#10;&amp;#10;This part is visual imagery practice. Each trial has 3 parts: imagining, rating, answering question.&amp;#10;&amp;#10;In imagination stage, you will see only a grey background. First, you’ll hear a “Ding”, followed by a brief description of an object (e.g., “A red bus”). Your task is to vividly imagine the object in your mind—as quickly and clearly as possible—against the grey background, and hold the image until the next stage.&amp;#10;After the imagination period, you will see reference images for different vividness from left to right. You need to rate how vivid your imagery is with fingers of your left hand, little finger for least vivid and thumb for most vivid. If you couldn’t understand what you heard or couldn’t form any image at all, press the button under your left little finger.&amp;#10;Finally, you will then be asked a simple yes/no question about the object (e.g., “Is it food?”). Please respond using right hand: index finger for YES, middle finger for NO, ring finger  for DON'T KNOW (if you didn’t understand what the object is).&amp;#10;&amp;#10;Different levels of image (example of 'A red bus'):&amp;#10;&amp;#10;&amp;#10;&amp;#10;&amp;#10;You will now begin a practice round. Please let the experimenter know when you are ready." valType="str" updates="constant" name="text"/>
        <Param val="from exp settings" valType="str" updates="None" name="units"/>
        <Param val="" valType="code" updates="None" name="validator"/>
        <Param val="1.2" valType="num" updates="constant" name="wrapWidth"/>
