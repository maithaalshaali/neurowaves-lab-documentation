        <Param val="" valType="code" updates="constant" name="stopVal"/>
        <Param val="True" valType="bool" updates="None" name="syncScreenRefresh"/>
        <Param val="Welcome to the experiment!&amp;#10;&amp;#10;Each trial has two parts: imagining and rating.&amp;#10;&amp;#10;In imagination stage, you will see only a grey background. First, you’ll hear a “Ding”, followed by a brief description of an object (e.g., “A red bus”). Your task is to vividly imagine the object in your mind, as clearly as you can, against the grey background. In the first block, you will have 1 second to imagine the object. In the second block, you will have 4 seconds. After the imagination period, you will be asked a simple yes/no question about the object (e.g., “Is it food?”). Please respond by pressing: 's' for YES, 'd' for NO, 'f' for DON'T KNOW (if you didn’t understand what the object is).&amp;#10;&amp;#10;In rating stage, a reference image of the object will appear on screen. Use your mouse to adjust the vividness slider: move the slider to right if your mental image was more vivid, move the slider to left if it was less vivid. Please choose the image that best matches how vivid your mental image felt, not the one that looks the most vivid. Please focus only on vividness and do not have to consider other factors. Use your first impression to rate — there are no right or wrong answers, and no penalty if your image wasn’t very clear. Once you're happy with your rating, press 's' to continue. Each trial ends with a brief rest period showing only the grey background.&amp;#10;&amp;#10;Different levels of image (example of 'A red bus'):&amp;#10;&amp;#10;&amp;#10;&amp;#10;&amp;#10;Now you will have a practice before the main experiment. If you understand everything, press 's' to start! " valType="str" updates="constant" name="text"/>
        <Param val="from exp settings" valType="str" updates="None" name="units"/>
        <Param val="" valType="code" updates="None" name="validator"/>
        <Param val="1.2" valType="num" updates="constant" name="wrapWidth"/>
