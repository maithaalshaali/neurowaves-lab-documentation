        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="import random&amp;#10;&amp;#10;# Create a list of image names with specified counts&amp;#10;WM_T_image_pool = ['6.jpg'] * 35 + ['8.jpg'] * 35 + ['10.jpg'] * 30&amp;#10;random.shuffle(WM_T_image_pool)&amp;#10;# Initialize a counter&amp;#10;WM_T_image_index = 0" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="import * as random from 'random';&amp;#10;WM_T_image_pool = ((([&quot;6.jpg&quot;] * 35) + ([&quot;8.jpg&quot;] * 35)) + ([&quot;10.jpg&quot;] * 30));&amp;#10;Math.random.shuffle(WM_T_image_pool);&amp;#10;WM_T_image_index = 0;&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="WM_T_chosen_image = WM_T_image_pool[WM_T_image_index];&amp;#10;WM_T_image_index += 1;&amp;#10;psychoJS.experiment.addData(&quot;chosen_image&quot;, WM_T_chosen_image);&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="# Get the next image&amp;#10;WM_T_chosen_image = WM_T_image_pool[WM_T_image_index]&amp;#10;WM_T_image_index += 1&amp;#10;&amp;#10;# Set the image for this trial&amp;#10;# WM_Test_Image.setImage('imgs_diffusion/' + Object + WM_T_chosen_image)&amp;#10;&amp;#10;thisExp.addData('chosen_image', WM_T_chosen_image)" valType="extendedCode" updates="constant" name="Begin Routine"/>
