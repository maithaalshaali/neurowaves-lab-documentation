        <Param val="rating = P_Slider.getRating()&amp;#10;&amp;#10;# If participant didn't move the slider, use the current marker position&amp;#10;if rating is None:&amp;#10;    rating = P_Slider.markerPos  # fallback to the default or current position&amp;#10;&amp;#10;# Now safely try to load the image based on the rating value&amp;#10;if rating is not None:&amp;#10;    try:&amp;#10;        P_Image.setImage('imgs_diffusion/' + Object + str(int(rating)) + '.jpg')&amp;#10;    except Exception as e:&amp;#10;        print(f'Error loading image: {e}')&amp;#10;&amp;#10;&amp;#10;" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="rating = P_Slider.getRating();&amp;#10;if ((rating === null)) {&amp;#10;    rating = P_Slider.markerPos;&amp;#10;}&amp;#10;if ((rating !== null)) {&amp;#10;    try {&amp;#10;        P_Image.setImage((((&quot;imgs_diffusion/&quot; + Object) + Number.parseInt(rating).toString()) + &quot;.jpg&quot;));&amp;#10;    } catch(e) {&amp;#10;        console.log(`Error loading image: ${e}`);&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Each JS Frame"/>
