      <CodeComponent name="WM_P_B2_Code" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="import * as random from 'random';&amp;#10;B2_allObjs = [&quot;rose&quot;, &quot;bear&quot;, &quot;taxi&quot;, &quot;lamp&quot;, &quot;cake&quot;, &quot;cat&quot;, &quot;lettuce&quot;, &quot;cup&quot;, &quot;table&quot;, &quot;sweater&quot;, &quot;chilli&quot;, &quot;spider&quot;, &quot;duck&quot;, &quot;coin&quot;, &quot;onion&quot;, &quot;chair&quot;, &quot;snake&quot;, &quot;bottle&quot;, &quot;coconut&quot;, &quot;pigeon&quot;, &quot;cap&quot;, &quot;suit&quot;, &quot;banana&quot;, &quot;kettle&quot;, &quot;dress&quot;, &quot;pepper&quot;, &quot;parrot&quot;, &quot;shirt&quot;, &quot;suitcase&quot;, &quot;mouse&quot;, &quot;mailbox&quot;, &quot;belt&quot;, &quot;corn&quot;, &quot;ring&quot;, &quot;eggplant&quot;, &quot;carrot&quot;, &quot;cucumber&quot;, &quot;butterfly&quot;, &quot;jacket&quot;, &quot;wolf&quot;];&amp;#10;i = WM_B2_Trials.thisIndex;&amp;#10;function get_j(i) {&amp;#10;    var offsets, valid_js;&amp;#10;    offsets = [10, 20, 30, (- 10), (- 20), (- 30)];&amp;#10;    valid_js = function () {&amp;#10;    var _pj_a = [], _pj_b = offsets;&amp;#10;    for (var _pj_c = 0, _pj_d = _pj_b.length; (_pj_c &lt; _pj_d); _pj_c += 1) {&amp;#10;        var offset = _pj_b[_pj_c];&amp;#10;        if (((0 &lt;= (i + offset)) &amp;&amp; ((i + offset) &lt;= 39))) {&amp;#10;            _pj_a.push((i + offset));&amp;#10;        }&amp;#10;    }&amp;#10;    return _pj_a;&amp;#10;}&amp;#10;.call(this);&amp;#10;    j = Math.random.choice(valid_js);&amp;#10;    return j;&amp;#10;}&amp;#10;j = get_j(i);&amp;#10;img1 = ((&quot;imgs_diffusion/&quot; + B2_allObjs[i]) + &quot;10.jpg&quot;);&amp;#10;img2 = ((&quot;imgs_diffusion/&quot; + B2_allObjs[j]) + &quot;10.jpg&quot;);&amp;#10;image_pair = [img1, img2];&amp;#10;Math.random.shuffle(image_pair);&amp;#10;imgA = image_pair[0];&amp;#10;imgB = image_pair[1];&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="##### make sure allObjs have same order as the loop file WM_Objects.csv!!!!!!&amp;#10;B2_allObjs = [&amp;#10;&quot;rose&quot;, &quot;bear&quot;, &quot;taxi&quot;, &quot;lamp&quot;, &quot;cake&quot;, &quot;cat&quot;, &quot;lettuce&quot;, &quot;cup&quot;, &quot;table&quot;, &quot;sweater&quot;, &amp;#10;&quot;chilli&quot;, &quot;spider&quot;, &quot;duck&quot;, &quot;coin&quot;, &quot;onion&quot;, &quot;chair&quot;, &quot;snake&quot;, &quot;bottle&quot;, &quot;coconut&quot;, &quot;pigeon&quot;, &amp;#10;&quot;cap&quot;, &quot;suit&quot;, &quot;banana&quot;, &quot;kettle&quot;, &quot;dress&quot;, &quot;pepper&quot;, &quot;parrot&quot;, &quot;shirt&quot;, &quot;suitcase&quot;, &quot;mouse&quot;, &amp;#10;&quot;mailbox&quot;, &quot;belt&quot;, &quot;corn&quot;, &quot;ring&quot;, &quot;eggplant&quot;, &quot;carrot&quot;, &quot;cucumber&quot;, &quot;butterfly&quot;, &quot;jacket&quot;, &quot;wolf&quot;&amp;#10;]&amp;#10;&amp;#10;# Get current index&amp;#10;i = WM_B2_Trials.thisIndex  # or your_trial_handler.thisN&amp;#10;&amp;#10;def get_j(i):&amp;#10;    offsets = [10, 20, 30, -10, -20, -30]&amp;#10;    valid_js = [i + offset for offset in offsets if 0 &lt;= i + offset &lt;= 39]&amp;#10;    j = random.choice(valid_js)&amp;#10;    return j&amp;#10;&amp;#10;j = get_j(i)&amp;#10;&amp;#10;# Define image filenames&amp;#10;img1 = 'imgs_diffusion/' + B2_allObjs[i] + '10.jpg'&amp;#10;img2 = 'imgs_diffusion/' + B2_allObjs[j] + '10.jpg'  # Object_list is the full list of objects&amp;#10;&amp;#10;# Randomize order&amp;#10;import random&amp;#10;image_pair = [img1, img2]&amp;#10;random.shuffle(image_pair)&amp;#10;&amp;#10;# Assign to variables used by Image components&amp;#10;imgA = image_pair[0]&amp;#10;imgB = image_pair[1]&amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="WM_P_B2_Code" valType="code" updates="None" name="name"/>
      </CodeComponent>
