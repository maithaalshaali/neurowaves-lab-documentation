        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="import * as random from 'random';&amp;#10;allObjs = [&quot;bus&quot;, &quot;sunflower&quot;, &quot;cabbage&quot;, &quot;strawberry&quot;, &quot;pineapple&quot;, &quot;leaf&quot;];&amp;#10;i = WM_P_Trials.thisIndex;&amp;#10;if ((i &gt;= 3)) {&amp;#10;    j = (i - 3);&amp;#10;} else {&amp;#10;    j = (i + 3);&amp;#10;}&amp;#10;img1 = ((&quot;imgs_diffusion/&quot; + allObjs[i]) + &quot;10.jpg&quot;);&amp;#10;img2 = ((&quot;imgs_diffusion/&quot; + allObjs[j]) + &quot;10.jpg&quot;);&amp;#10;image_pair = [img1, img2];&amp;#10;Math.random.shuffle(image_pair);&amp;#10;imgA = image_pair[0];&amp;#10;imgB = image_pair[1];&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="##### make sure allObjs have same order as the loop file WM_Objects.csv!!!!!!&amp;#10;allObjs = [&amp;#10;&quot;bus&quot;,&amp;#10;&quot;sunflower&quot;,&amp;#10;&quot;cabbage&quot;,&amp;#10;&quot;strawberry&quot;,&amp;#10;&quot;pineapple&quot;,&amp;#10;&quot;leaf&quot;&amp;#10;]&amp;#10;&amp;#10;# Get current index&amp;#10;i = WM_P_Trials.thisIndex  # or your_trial_handler.thisN&amp;#10;&amp;#10;# Wrap-around logic for second image index&amp;#10;if i &gt;= 3:&amp;#10;    j = i - 3  # i = 70–79 → j = 0–9&amp;#10;else:&amp;#10;    j = i + 3&amp;#10;&amp;#10;# Define image filenames&amp;#10;img1 = 'imgs_diffusion/' + allObjs[i] + '10.jpg'&amp;#10;img2 = 'imgs_diffusion/' + allObjs[j] + '10.jpg'  # Object_list is the full list of objects&amp;#10;&amp;#10;# Randomize order&amp;#10;import random&amp;#10;image_pair = [img1, img2]&amp;#10;random.shuffle(image_pair)&amp;#10;&amp;#10;# Assign to variables used by Image components&amp;#10;imgA = image_pair[0]&amp;#10;imgB = image_pair[1]" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
